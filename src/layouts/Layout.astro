---
import '../styles/global.css';
const { title = 'ComfyUI Prompts', description = 'ComfyUI 中文提示詞資料庫 - 風格轉換、寫實人像、角色設計' } = Astro.props;
const base = '/comfyui-prompts';
---
<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={base + '/favicon.svg'} />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <nav>
        <a href={base} class="logo">
          <span class="logo-icon">🎨</span>
          <span class="logo-text">ComfyUI Prompts</span>
        </a>
        <div class="nav-links">
          <a href={base} class="nav-link">首頁</a>
          <a href={base + '/prompts'} class="nav-link">提示詞</a>
          <a href={base + '/guide'} class="nav-link">參數指南</a>
          <a href={base + '/workflow'} class="nav-link">工作流</a>
          <a href={base + '/blog'} class="nav-link">教學</a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>© 2026 ComfyUI Prompts — 由 AI 生成的提示詞資料庫</p>
    </footer>
  </body>
</html>
