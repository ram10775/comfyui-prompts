---
import Layout from '../layouts/Layout.astro';
import promptsData from '../data/prompts.json';

const categories = promptsData.categories;
const totalPrompts = categories.reduce((sum, cat) => sum + cat.prompts.length, 0);
const base = "/comfyui-prompts";
---
<Layout title="ComfyUI Prompts - 中文提示詞資料庫" description="ComfyUI + Qwen GGUF 中文提示詞資料庫，涵蓋風格轉換、寫實人像、角色設計、商業應用等 20+ 經實測有效的提示詞" />

<section class="hero">
  <div class="container">
    <h1>🎨 ComfyUI 提示詞資料庫</h1>
    <p>基於 Qwen Image Edit GGUF 實測有效的中文提示詞集合<br />
    涵蓋 風格轉換 · 寫實人像 · 角色設計 · 商業應用</p>

    <div class="search-box">
      <span class="search-icon">🔍</span>
      <input type="text" id="search" placeholder="搜尋提示詞... (例: 吉卜力、人像、水彩)" />
    </div>

    <div class="stats">
      <div class="stat">
        <div class="stat-number">{totalPrompts}+</div>
        <div class="stat-label">提示詞</div>
      </div>
      <div class="stat">
        <div class="stat-number">{categories.length}</div>
        <div class="stat-label">分類</div>
      </div>
      <div class="stat">
        <div class="stat-number">100%</div>
        <div class="stat-label">實測有效</div>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <h2 class="section-title">📂 瀏覽分類</h2>
    <div class="categories-grid">
      {categories.map(cat => (
        <a href={`/comfyui-prompts/prompts/${cat.id}/`} class="category-card">
          <div class="category-icon">{cat.icon}</div>
          <h3>{cat.name}</h3>
          <p>{cat.description}</p>
          <span class="category-count">{cat.prompts.length} 筆提示詞</span>
        </a>
      ))}
    </div>
  </div>
</section>

<section class="section" style="background: var(--bg-secondary); padding: 60px 24px;">
  <div class="container">
    <h2 class="section-title">⚡ 快速開始</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px;">
      <div style="background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 24px;">
        <h3 style="margin-bottom: 12px; color: var(--accent);">1. 選擇提示詞</h3>
        <p style="color: var(--text-secondary); font-size: 0.9rem;">從資料庫中找到你需要的提示詞，點擊即可複製中文或英文版本</p>
      </div>
      <div style="background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 24px;">
        <h3 style="margin-bottom: 12px; color: var(--accent);">2. 設定參數</h3>
        <p style="color: var(--text-secondary); font-size: 0.9rem;">使用建議的 denoise / cfg / steps 參數，直接套用即可出圖</p>
      </div>
      <div style="background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 24px;">
        <h3 style="margin-bottom: 12px; color: var(--accent);">3. 在 ComfyUI 執行</h3>
        <p style="color: var(--text-secondary); font-size: 0.9rem;">將提示詞貼到 ComfyUI CLIPTextEncode 節點，按下 Queue Prompt 即可</p>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <h2 class="section-title">🔥 熱門提示詞</h2>
    <div class="prompts-grid">
      {categories.flatMap(cat => cat.prompts).slice(0, 6).map(prompt => {
        const catInfo = categories.find(c => c.prompts.some(p => p.id === prompt.id))!;
        return (
          <a href={base + `/prompts/${catInfo.id}/${prompt.id}/`} class="prompt-card-link">
            <div class="prompt-card">
              <div class="prompt-header">
                <span class="prompt-title">{prompt.title}</span>
                <span class="prompt-tag">免費</span>
              </div>
              <div class="prompt-tags">
                {prompt.tags.map(tag => <span>{tag}</span>)}
              </div>
              <div class="prompt-text" data-prompt={prompt.prompt_zh}>
                {prompt.prompt_zh}
              </div>
              <div class="params-grid">
                <div class="param">
                  <div class="param-label">denoise</div>
                  <div class="param-value">{prompt.params.denoise}</div>
                </div>
                <div class="param">
                  <div class="param-label">cfg</div>
                  <div class="param-value">{prompt.params.cfg}</div>
                </div>
                <div class="param">
                  <div class="param-label">steps</div>
                  <div class="param-value">{prompt.params.steps}</div>
                </div>
                <div class="param">
                  <div class="param-label">解析度</div>
                  <div class="param-value">{prompt.params.resolution}</div>
                </div>
              </div>
              <div class="tip">💡 {prompt.tips}</div>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>

<!-- FAQ Section -->
<section class="section" style="background: var(--bg-secondary); padding: 60px 24px;">
  <div class="container" style="max-width: 800px;">
    <h2 class="section-title">❓ 常見問題</h2>
    <div class="faq-list">
      <details class="faq-item">
        <summary>什麼是 ComfyUI？</summary>
        <p>ComfyUI 是一個開源的 AI 繪圖工具，使用節點式工作流來控制生成過程。相較於 Stable Diffusion WebUI，它有更高的靈活性和效能。搭配 Qwen Image Edit GGUF 模型，可以直接使用中文提示詞生成圖片。</p>
      </details>
      <details class="faq-item">
        <summary>這個網站的提示詞可以用在哪些模型？</summary>
        <p>本站所有提示詞都經過 Qwen Image Edit GGUF 模型實測驗證。這個模型原生支援中英雙語，不需翻譯即可直接使用中文提示詞。</p>
      </details>
      <details class="faq-item">
        <summary>img2img 的 denoise 參數是什麼？</summary>
        <p>denoise 決定原圖保留程度與風格轉換強度。數值越低越接近原圖（0.3-0.4 幾乎是原圖），數值越高風格化越強（0.85 幾乎是重繪）。一般推薦從 0.5 開始調整。</p>
      </details>
      <details class="faq-item">
        <summary>免費使用這些提示詞嗎？</summary>
        <p>是的！本站所有提示詞皆免費使用。你可以複製貼上到 ComfyUI 直接使用，也可以分享給朋友。</p>
      </details>
      <details class="faq-item">
        <summary>需要什麼硬體才能跑 ComfyUI？</summary>
        <p>建議至少有 NVIDIA 顯卡（4GB+ VRAM）。本站提示詞使用 512x512 解析度，在 V100 32GB 上約 2 分鐘可完成。低階顯卡可能需要更長時間。</p>
      </details>
      <details class="faq-item">
        <summary>為什麼推薦用 Qwen 而不是 SD 1.5？</summary>
        <p>Qwen Image Edit GGUF 原生支援中文提示詞，不需額外翻譯。img2img 風格轉換效果優於 SD 1.5，且可以使用 GGUF 量化版本節省記憶體。</p>
      </details>
    </div>
  </div>
</section>

