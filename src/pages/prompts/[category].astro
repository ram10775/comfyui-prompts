---
import Layout from '../../layouts/Layout.astro';
import promptsData from '../../data/prompts.json';

export async function getStaticPaths() {
  return promptsData.categories.map(cat => ({
    params: { category: cat.id },
    props: { cat },
  }));
}

const { cat } = Astro.props;
const base = "/comfyui-prompts";
---
<Layout title={`${cat.name} - ComfyUI Prompts`} description={`${cat.name} | ComfyUI + Qwen GGUF ${cat.description}`} />

<div class="container" style="padding: 40px 24px;">
  <div class="breadcrumb">
    <a href={base}>首頁</a> <span>›</span>
    <a href={base + '/prompts/'}>所有提示詞</a> <span>›</span>
    {cat.name}
  </div>

  <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 8px;">
    <span style="font-size: 2.5rem;">{cat.icon}</span>
    <h1 style="font-size: 2rem;">{cat.name}</h1>
  </div>
  <p style="color: var(--text-secondary); margin-bottom: 32px;">{cat.description}</p>

  <div class="prompts-grid">
    {cat.prompts.map(prompt => (
      <div class="prompt-card">
        <div class="prompt-header">
          <span class="prompt-title">{prompt.title}</span>
          <span class="prompt-tag">免費</span>
        </div>
        <div class="prompt-tags">
          {prompt.tags.map(tag => <span>{tag}</span>)}
        </div>
        <div class="prompt-text" data-prompt={prompt.prompt_zh}>
          {prompt.prompt_zh}
        </div>

        <details style="margin-bottom: 12px;">
          <summary style="cursor: pointer; color: var(--accent); font-size: 0.85rem;">📝 英文提示詞</summary>
          <div class="prompt-text" data-prompt={prompt.prompt_en} style="margin-top: 8px;">
            {prompt.prompt_en}
          </div>
        </details>

        <div class="params-grid">
          <div class="param">
            <div class="param-label">denoise</div>
            <div class="param-value">{prompt.params.denoise}</div>
          </div>
          <div class="param">
            <div class="param-label">cfg</div>
            <div class="param-value">{prompt.params.cfg}</div>
          </div>
          <div class="param">
            <div class="param-label">steps</div>
            <div class="param-value">{prompt.params.steps}</div>
          </div>
          <div class="param">
            <div class="param-label">解析度</div>
            <div class="param-value">{prompt.params.resolution}</div>
          </div>
        </div>
        <div class="tip">💡 {prompt.tips}</div>
      </div>
    ))}
  </div>
</div>
